# Copie este arquivo para .env.local (uso local) e configure também
# no painel do Vercel em Settings -> Environment Variables.

# Chave secreta usada para assinar (HMAC-SHA256) cada certificado.
# Gere uma chave forte, por exemplo com:
#   openssl rand -hex 32
SIGNING_SECRET=coloque-aqui-uma-chave-bem-grande-e-aleatoria
